                "Spark",
                "Jupyter",
                "DataWarehouse"
            ],
            "x-ms-enum": {
                "name": "ComputeType",
                "modelAsString": true,
                "values": [
                    {
                        "value": "Spark",
                        "description": "Spark compute type."
                    },
                    {
                        "value": "Jupyter",
                        "description": "Jupyter compute type."
                    },
                    {
                        "value": "DataWarehouse",
                        "description": "Data Warehouse compute type."
                    }
                ]
            }
