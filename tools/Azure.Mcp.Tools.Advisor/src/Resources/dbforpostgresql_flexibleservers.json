{
  "rules": [
    {
      "ruleId": "Enable_Custom_Maintenance_Schedule_PostgreSQL_Flexible_Server",
      "description": "Use custom maintenance schedule on flexible server instances to select a preferred time for service updates to be applied.",
      "query": "where properties.maintenanceWindow.customWindow != 'Enabled'",
      "ARM_Query": {
        "allOf": [
          {
            "field": "properties.maintenanceWindow.customWindow",
            "notEquals": "Enabled"
          }
        ]
      },
      "fix": "Use custom maintenance schedule on flexible server instances to select a preferred time for service updates to be applied",
      "ARM_Fix": {
        "type": "propertyUpdate",
        "operations": [
          {
            "field": "properties.maintenanceWindow.customWindow",
            "value": "Enabled"
          },
          {
            "field": "properties.maintenanceWindow.dayOfWeek",
            "value": 0
          },
          {
            "field": "properties.maintenanceWindow.startHour",
            "value": 2
          },
          {
            "field": "properties.maintenanceWindow.startMinute",
            "value": 0
          }
        ]
      },
      "TF_Query": {
        "resource_type": "azurerm_postgresql_flexible_server",
        "allOf": [
          {
            "attribute": "maintenance_window",
            "exists": false
          }
        ]
      },
      "TF_Fix": {
        "type": "attributeUpdate",
        "operations": [
          {
            "attribute": "maintenance_window.day_of_week",
            "value": 0
          },
          {
            "attribute": "maintenance_window.start_hour",
            "value": 2
          },
          {
            "attribute": "maintenance_window.start_minute",
            "value": 0
          }
        ]
      }
    }
  ]
}